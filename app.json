{
  "expo": {
    "name": "AgroSafra",
    "slug": "agrosafra",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "agrosafra",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.agrosafra.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8e1b72f1-8bbd-493b-a5ab-d5c8e3c9d2f7"
      }
    }
  }
}
