{
  "expo": {
    "name": "AgroSafra",
    "slug": "agrosafra",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "agrosafra",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.agrosafra.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [{ "scheme": "agrosafra" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "AgroSafra usa o microfone para gravar áudios do Talk Pro."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AgroSafra usa a localização para o botão SOS e para o Clima."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8e1b72f1-8bbd-493b-a5ab-d5c8e3c9d2f7"
      }
    }
  }
}
